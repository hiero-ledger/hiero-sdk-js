    "types": "./lib/index.d.ts",
    "module": "./src/index.js",
    "react-native": {
        "./lib/index.cjs": "./src/index.native.js"
    },
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "react-native": "./src/index.native.js",
            "types": "./lib/index.d.ts",
            "import": "./src/index.js",
            "require": "./lib/index.cjs"
        }
    },
