{
  "name": "@hiero-ledger/proto",
  "version": "2.28.0",
  "description": "Protobufs for the Hiero SDK",
  "main": "lib/index.js",
  "browser": "src/index.js",
  "types": "lib/index.d.ts",
  "sideEffects": [
    "./lib/index.js",
    "./lib/proto.js",
    "./src/index.js",
    "./src/proto.js"
  ],
  "typesVersions": {
    "*": {
      "minimal": [
        "./lib/minimal/index.d.ts"
      ],
      "minimal/*": [
        "./lib/minimal/*"
      ]
    }
  },
  "license": "Apache-2.0",
  "author": "Launchbadge <contact@launchbadge.com>",
  "repository": "https://github.com/hiero-ledger/hiero-sdk-js",
  "bugs": "https://github.com/hiero-ledger/hiero-sdk-js/issues",
  "keywords": [
    "hiero",
    "hedera",
    "hashgraph",
    "sdk",
    "transactions"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./minimal": {
      "import": "./src/minimal/index.js",
      "require": "./lib/minimal/index.js",
      "types": "./lib/minimal/index.d.ts"
    },
    "./minimal/*": {
      "import": "./src/minimal/*.js",
      "require": "./lib/minimal/*.js",
      "types": "./lib/minimal/*.d.ts"
    }
  },
  "files": [
    "lib/",
    "src/"
  ],
  "engines": {
    "node": ">=10.0.0"
  },
  "browserslist": [
    "last 1 Chrome versions",
    "last 1 Firefox versions"
  ],
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "long": "5.3.1",
    "rimraf": "6.1.2"
  },
  "devDependencies": {
    "@babel/cli": "7.23.4",
    "@babel/core": "7.23.3",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-transform-export-namespace-from": "7.22.3",
    "@babel/plugin-transform-modules-commonjs": "7.20.11",
    "@babel/plugin-transform-runtime": "7.25.9",
    "@bufbuild/buf": "1.68.2",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "babel-plugin-dynamic-import-node": "2.3.3",
    "babel-preset-minify": "0.5.2",
    "chalk": "5.2.0",
    "copyfiles": "2.4.1",
    "escodegen": "2.0.0",
    "eslint": "8.52.0",
    "eslint-plugin-compat": "6.1.0",
    "eslint-plugin-deprecation": "3.0.0",
    "eslint-plugin-ie11": "1.0.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-jsdoc": "62.5.5",
    "eslint-plugin-n": "17.15.1",
    "estraverse": "5.3.0",
    "jsdoc": "4.0.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.0.3",
    "protobufjs-cli": "2.0.1",
    "replace-in-file": "8.3.0",
    "semver": "7.3.8",
    "tmp": "0.2.4",
    "ts-proto": "2.11.6",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "ansi-regex": "6.2.2",
    "ansi-styles": "6.2.3",
    "debug": "4.4.1",
    "protobufjs": "8.0.1",
    "strip-ansi": "7.1.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
