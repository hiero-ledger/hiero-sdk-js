# Hiero SDK React Native Example - Environment Configuration
#
# To use this example, you need a Hiero testnet account.
# Get one free at: https://portal.hedera.com/register
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Your Hiero/Hedera Operator Account ID (e.g., 0.0.12345)
EXPO_PUBLIC_OPERATOR_ID="0.0.12345"

# Your Hiero/Hedera Operator Private Key (DER-encoded hex string)
EXPO_PUBLIC_OPERATOR_KEY="302e020100300506032b6570042204..."

# Network to connect to: "testnet" or "previewnet"
EXPO_PUBLIC_HEDERA_NETWORK="testnet"
